{
  "name": "fe-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "React.js, Next.js, and Expo Monorepo Template",
  "author": "Tri Rizeki Rifandani",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "compose:up": "docker compose -f docker/docker-compose.yml up --build",
    "clean": "rimraf --glob \"**/node_modules\" \"**/dev-dist\" \"**/dist\" \"**/build\" \"**/html\" \"**/playwright\" \"**/playwright-report\" \"**/playwright-test-results\" \"**/bun.lock\" \"**/.next\" \"**/.tanstack\" \"**/.expo\" \"**/.tamagui\" && bun pm cache rm && bun install",
    "bump:deps": "bunx npm-check-updates --deep -u --peer -x expo*,@expo*,@dev-plugins*,@babel*,metro*,react-native*,@react-navigation*,tamagui,@tamagui*",
    "bump:ui": "bunx shadcn@latest add @intentui/all -o -c apps/spa",
    "cs": "changeset",
    "cs:v": "changeset version",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:doctor": "ultracite doctor",
    "typecheck": "bun run --parallel web:typecheck spa:typecheck expo:typecheck",
    "lint-typecheck": "bun run --parallel lint web:typecheck spa:typecheck expo:typecheck",
    "spa": "bun --elide-lines=0 --filter @workspace/spa",
    "web": "bun --elide-lines=0 --filter @workspace/web",
    "expo": "bun --elide-lines=0 --filter @workspace/expo",
    "spa:ci": "bun --elide-lines=0 --filter @workspace/spa",
    "web:ci": "bun --elide-lines=0 --filter @workspace/web",
    "expo:ci": "bun --elide-lines=0 --filter @workspace/expo",
    "spa:typecheck": "bun spa:ci typecheck",
    "web:typecheck": "bun web:ci typecheck",
    "expo:typecheck": "bun expo:ci typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@workspace/typescript-config": "workspace:*",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-plugin-react-doctor": "0.7.2",
    "rimraf": "6.1.3",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ]
}
