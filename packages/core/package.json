{
  "name": "@workspace/core",
  "version": "1.1.0",
  "private": true,
  "description": "Shared core module for React Monorepo",
  "license": "MIT",
  "author": "Tri Rizeki Rifandani",
  "type": "module",
  "exports": {
    "./apis/*": "./src/apis/*.ts",
    "./assets/*": "./src/assets/*",
    "./constants/*": "./src/constants/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./libs/*": "./src/libs/*.ts",
    "./services/*": "./src/services/*.ts",
    "./types/*": "./src/types/*.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "test:unit": "vitest run --project core"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "ky": "2.0.2",
    "radashi": "12.9.1",
    "react": ">=19.0.0",
    "type-fest": "5.8.0",
    "zod": "4.4.3"
  }
}
