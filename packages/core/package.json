{
  "name": "@workspace/core",
  "type": "module",
  "version": "1.1.0",
  "private": true,
  "description": "Shared core module for React Monorepo",
  "author": "Tri Rizeki Rifandani",
  "license": "MIT",
  "exports": {
    "./apis/*": "./src/apis/*.ts",
    "./assets/*": "./src/assets/*",
    "./constants/*": "./src/constants/*.ts",
