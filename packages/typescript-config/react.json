{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "esnext",
      "DOM",
      "WebWorker"
    ],
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "jsx": "preserve"
  }
}
